# Required: Groq API key for /api/chat and /api/arena
GROQ_API_KEY=your_groq_api_key_here

# Local server port
PORT=3000

# Preview iframe port exposed from Vercel Sandbox
PREVIEW_PORT=3000

# Fixed sandbox runtime (pins Node major via Vercel Sandbox runtime image)
SANDBOX_RUNTIME=node22

# Max validate/heal attempts per preview sync
MAX_VALIDATE_ATTEMPTS=4

# Minimum visible duration of one step event (ms)
MIN_STEP_DURATION_MS=250

# Timeout for build tool inside orchestrator (ms)
BUILD_TIMEOUT_MS=90000

# Optional: explicit Vercel Sandbox credentials (recommended for stable auth)
VERCEL_TOKEN=your_vercel_token_here
VERCEL_TEAM_ID=your_vercel_team_id_here
VERCEL_PROJECT_ID=your_vercel_project_id_here
